@model DoodleNoteDetailsViewModel
@{
    ViewData["Title"] = Model.NoteTitle;
}

<h1>@Model.NoteTitle</h1>
<div class="mb-2 text-muted">Created: @Model.CreatedDate.ToString("yyyy-MM-dd")</div>
<div class="mb-2"><strong>Author:</strong> @Model.Author</div>

@if (!string.IsNullOrWhiteSpace(Model.ImagePath))
{
    <div class="mb-4">
        <label class="form-label d-block">Doodle Image</label>
        <img src="@Url.Content(Model.ImagePath)" alt="Doodle image for @Model.NoteTitle" class="img-fluid rounded border" style="max-height: 420px;" />
    </div>
}

<div class="mb-3">
    <label class="form-label">Description</label>
    <div id="note-description" class="form-control" style="min-height: 80px; background: #f8f9fa;">@Model.Description</div>
</div>

<a class="btn btn-secondary" asp-action="Index">Back to List</a>


