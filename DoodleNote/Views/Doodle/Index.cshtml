@{
    ViewData["Title"] = "Doodle Board";
}

<div class="container-fluid px-0">
    <div class="d-flex flex-wrap gap-2 align-items-end mb-2">
        <div>
            <label class="form-label mb-1" for="toolSelect">Tool</label>
            <select id="toolSelect" class="form-select form-select-sm">
                <option value="pen" selected>Pen</option>
                <option value="eraser">Eraser</option>
                <option value="line">Line</option>
                <option value="rect">Rectangle</option>
                <option value="ellipse">Ellipse</option>
            </select>
        </div>

        <div>
            <label class="form-label mb-1" for="colorPicker">Color</label>
            <input id="colorPicker" type="color" class="form-control form-control-color form-control-sm" value="#111111" />
        </div>

        <div style="min-width: 160px;">
            <label class="form-label mb-1" for="sizeRange">Brush size: <span id="sizeValue">6</span></label>
            <input id="sizeRange" type="range" class="form-range" min="1" max="64" value="6" />
        </div>

        <div style="min-width: 160px;">
            <label class="form-label mb-1" for="smoothRange">Smoothing: <span id="smoothValue">0</span></label>
            <input id="smoothRange" type="range" class="form-range" min="0" max="100" value="0" />
        </div>

        <div class="form-check mb-1">
            <input class="form-check-input" type="checkbox" id="fillShapes" />
            <label class="form-check-label" for="fillShapes">Fill shapes</label>
        </div>

        <div style="min-width: 160px;">
            <label class="form-label mb-1" for="zoomRange">Zoom: <span id="zoomValue">100%</span></label>
            <input id="zoomRange" type="range" class="form-range" min="25" max="300" value="100" />
        </div>

        <div class="ms-auto d-flex flex-wrap gap-2">
            <button id="undoBtn" class="btn btn-sm btn-outline-secondary" type="button" disabled>Undo</button>
            <button id="redoBtn" class="btn btn-sm btn-outline-secondary" type="button" disabled>Redo</button>
            <button id="clearBtn" class="btn btn-sm btn-outline-danger" type="button">Clear</button>

            
             <button id="uploadBtn" class="btn btn-sm btn-success" type="button">Upload</button>
            <button id="saveBtn" class="btn btn-sm btn-primary" type="button">Save PNG</button>
        </div>
    </div>

    <form id="uploadForm" method="post" asp-controller="Doodle" asp-action="StartUpload" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="d-flex justify-content-center">
        <div id="canvasHost" class="border rounded bg-white shadow-sm" style="width: 420px; height: 420px; position: relative;">
            <canvas id="doodleCanvas" style="width: 100%; height: 100%; display: block; touch-action: none;"></canvas>
        </div>
    </div>

    <div class="text-muted small mt-2">
        Tip: Hold <kbd>Shift</kbd> while drawing shapes to constrain proportions (square/circle).
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const canvasHost = document.getElementById('canvasHost');
            const canvas = document.getElementById('doodleCanvas');

            const toolSelect = document.getElementById('toolSelect');
            const colorPicker = document.getElementById('colorPicker');
            const sizeRange = document.getElementById('sizeRange');
            const sizeValue = document.getElementById('sizeValue');
            const smoothRange = document.getElementById('smoothRange');
            const smoothValue = document.getElementById('smoothValue');
            const fillShapes = document.getElementById('fillShapes');
            const zoomRange = document.getElementById('zoomRange');
            const zoomValue = document.getElementById('zoomValue');

            const undoBtn = document.getElementById('undoBtn');
            const redoBtn = document.getElementById('redoBtn');
            const clearBtn = document.getElementById('clearBtn');
            const saveBtn = document.getElementById('saveBtn');
            const uploadBtn = document.getElementById('uploadBtn');

            // ---- Paper.js setup ----
            paper.setup(canvas);

            const state = {
                tool: toolSelect.value,
                color: colorPicker.value,
                width: Number(sizeRange.value),
                smoothing: Number(smoothRange.value) / 100,
                fill: fillShapes.checked,
                zoom: 1.0
            };

            // ---- History (snapshot-based) ----
            const undoStack = [];
            const redoStack = [];
            const MAX_HISTORY = 50;

            function exportSnapshot() {
                // Paper returns JSON string by default; keep it as a string for cheap storage.
                return paper.project.exportJSON({ asString: true, precision: 5 });
            }

            function importSnapshot(json) {
                paper.project.clear();
                paper.project.importJSON(json);
                paper.view.update();
            }

            function pushHistory() {
                undoStack.push(exportSnapshot());
                if (undoStack.length > MAX_HISTORY) undoStack.shift();
                redoStack.length = 0;
                updateHistoryButtons();
            }

            function updateHistoryButtons() {
                undoBtn.disabled = undoStack.length <= 1;
                redoBtn.disabled = redoStack.length === 0;
            }

            // Initialize history with blank canvas state
            pushHistory();
            
            // ---- UI bindings ----
            toolSelect.addEventListener('change', () => state.tool = toolSelect.value);

            colorPicker.addEventListener('input', () => state.color = colorPicker.value);

            sizeRange.addEventListener('input', () => {
                state.width = Number(sizeRange.value);
                sizeValue.textContent = String(state.width);
            });

            smoothRange.addEventListener('input', () => {
                state.smoothing = Number(smoothRange.value) / 100;
                smoothValue.textContent = state.smoothing.toFixed(2);
            });

            fillShapes.addEventListener('change', () => state.fill = fillShapes.checked);

            zoomRange.addEventListener('input', () => {
                const z = Number(zoomRange.value) / 100;
                state.zoom = z;
                paper.view.zoom = z;
                zoomValue.textContent = `${Math.round(z * 100)}%`;
            });

            undoBtn.addEventListener('click', () => {
                if (undoStack.length <= 1) return;
                const current = undoStack.pop();
                redoStack.push(current);
                importSnapshot(undoStack[undoStack.length - 1]);
                updateHistoryButtons();
            });

            redoBtn.addEventListener('click', () => {
                if (redoStack.length === 0) return;
                const next = redoStack.pop();
                undoStack.push(next);
                importSnapshot(next);
                updateHistoryButtons();
            });

            clearBtn.addEventListener('click', () => {
                paper.project.activeLayer.removeChildren();
                paper.view.update();
                pushHistory();
            });

            saveBtn.addEventListener('click', () => {
                // Export as PNG from the underlying canvas.
                const dataUrl = canvas.toDataURL('image/png');
                const a = document.createElement('a');
                a.href = dataUrl;
                a.download = `doodle-${new Date().toISOString().replace(/[:.]/g, '-')}.png`;
                document.body.appendChild(a);
                a.click();
                a.remove();
            });

            uploadBtn.addEventListener('click', async () => {
                const dataUrl = canvas.toDataURL('image/png');

                const antiForgeryToken = document.querySelector('#uploadForm input[name="__RequestVerificationToken"]').value;

                const response = await fetch('@Url.Action("StartUpload", "Doodle")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': antiForgeryToken
                    },
                    body: JSON.stringify({ pngDataUrl: dataUrl })
                });

                if (!response.ok) {
                    const text = await response.text();
                    alert(`Upload failed: ${text}`);
                    return;
                }

                const json = await response.json();
                window.location.href = json.redirectUrl;
            });

            // ---- Drawing tool (supports pen/eraser/shapes) ----
            let activeItem = null;
            let startPoint = null;

            function makeStrokeStyle() {
                return {
                    strokeColor: state.color,
                    strokeWidth: state.width,
                    strokeCap: 'round',
                    strokeJoin: 'round'
                };
            }

            function applyShapeStyle(item) {
                item.strokeColor = state.color;
                item.strokeWidth = Math.max(1, Math.floor(state.width));
                item.strokeJoin = 'round';

                if (state.fill) item.fillColor = state.color;
                else item.fillColor = null;
            }

            const tool = new paper.Tool();
            tool.minDistance = 1;

            tool.onMouseDown = (event) => {
                startPoint = event.point.clone();
                activeItem = null;

                if (state.tool === 'pen') {
                    activeItem = new paper.Path(makeStrokeStyle());
                    activeItem.add(event.point);
                } else if (state.tool === 'eraser') {
                    // True eraser by punching out pixels:
                    activeItem = new paper.Path({
                        strokeColor: 'black',
                        strokeWidth: Math.max(4, state.width * 2),
                        strokeCap: 'round',
                        strokeJoin: 'round',
                        blendMode: 'destination-out'
                    });
                    activeItem.add(event.point);
                } else if (state.tool === 'line') {
                    activeItem = new paper.Path(makeStrokeStyle());
                    activeItem.add(event.point);
                    activeItem.add(event.point);
                } else if (state.tool === 'rect') {
                    activeItem = new paper.Path.Rectangle(new paper.Rectangle(event.point, event.point));
                    applyShapeStyle(activeItem);
                } else if (state.tool === 'ellipse') {
                    activeItem = new paper.Path.Ellipse(new paper.Rectangle(event.point, event.point));
                    applyShapeStyle(activeItem);
                }
            };

            tool.onMouseDrag = (event) => {
                if (!activeItem) return;

                if (state.tool === 'pen' || state.tool === 'eraser') {
                    activeItem.add(event.point);
                    return;
                }

                // Shapes: rebuild from start to current point
                const endPoint = event.point.clone();
                const constrain = event.modifiers.shift === true;

                let rect = new paper.Rectangle(startPoint, endPoint);

                if (constrain) {
                    // Make it a square based on the max dimension
                    const size = Math.max(Math.abs(rect.width), Math.abs(rect.height));
                    const sx = rect.width < 0 ? -1 : 1;
                    const sy = rect.height < 0 ? -1 : 1;
                    rect = new paper.Rectangle(startPoint, startPoint.add(new paper.Point(size * sx, size * sy)));
                }

                activeItem.remove();

                if (state.tool === 'line') {
                    activeItem = new paper.Path(makeStrokeStyle());
                    activeItem.add(startPoint);
                    activeItem.add(endPoint);
                } else if (state.tool === 'rect') {
                    activeItem = new paper.Path.Rectangle(rect);
                    applyShapeStyle(activeItem);
                } else if (state.tool === 'ellipse') {
                    activeItem = new paper.Path.Ellipse(rect);
                    applyShapeStyle(activeItem);
                }
            };

            tool.onMouseUp = () => {
                if (!activeItem) return;

                if (state.tool === 'pen' && state.smoothing > 0) {
                    // Light smoothing: simplify then smooth
                    try {
                        activeItem.simplify(Math.max(0.1, state.smoothing * 8));
                        activeItem.smooth({ type: 'continuous' });
                    } catch { /* ignore smoothing errors */ }
                }

                paper.view.update();
                pushHistory();

                activeItem = null;
                startPoint = null;
            };
        })();
    </script>
}