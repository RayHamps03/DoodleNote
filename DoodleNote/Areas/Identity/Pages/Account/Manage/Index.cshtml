@page
@model DoodleNote.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Manage Profile";
    ViewData["ActivePage"] = "Index";

    if (Model?.CurrentUser == null)
    {
        <div class="alert alert-danger">User information could not be loaded. Please try again.</div>
        return;
    }

    var currentUsername = System.Web.HttpUtility.JavaScriptStringEncode(Model.CurrentUser.UserName ?? "");
    var currentPhone = System.Web.HttpUtility.JavaScriptStringEncode(Model.CurrentUser.PhoneNumber ?? "");
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>@ViewData["Title"]</h2>

            @Html.AntiForgeryToken()

            <div class="card">
                <div class="card-body">
                    <div class="form-group">
                        <label for="usernameDisplay" class="form-label">Username</label>
                        <div class="input-group">
                            <input type="text" id="usernameDisplay" class="form-control" value="@Model.CurrentUser.UserName" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="editUsernameBtn" title="Edit username">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                        </div>
                    </div>

                    <div id="editModeContainer" class="form-group d-none mt-3">
                        <label for="usernameInput" class="form-label">New Username</label>
                        <div class="input-group">
                            <input type="text" id="usernameInput" class="form-control" value="@Model.CurrentUser.UserName" />
                            <button type="button" class="btn btn-success" id="saveUsernameBtn">
                                <i class="bi bi-check"></i> Save
                            </button>
                            <button type="button" class="btn btn-secondary" id="cancelUsernameBtn">
                                <i class="bi bi-x"></i> Cancel
                            </button>
                        </div>
                        <small id="errorMessage" class="text-danger d-none mt-2"></small>
                    </div>

                    <hr class="my-4" />

                    <div class="form-group">
                        <label for="phoneDisplay" class="form-label">Phone Number</label>
                        <div class="input-group">
                            <input type="text" id="phoneDisplay" class="form-control" value="@(Model.CurrentUser.PhoneNumber ?? "Not set")" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="editPhoneBtn" title="Edit phone number">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                        </div>
                    </div>

                    <div id="editPhoneModeContainer" class="form-group d-none mt-3">
                        <label for="phoneInput" class="form-label">New Phone Number</label>
                        <div class="input-group">
                            <input type="tel" id="phoneInput" class="form-control" value="@(Model.CurrentUser.PhoneNumber ?? "")" />
                            <button type="button" class="btn btn-success" id="savePhoneBtn">
                                <i class="bi bi-check"></i> Save
                            </button>
                            <button type="button" class="btn btn-secondary" id="cancelPhoneBtn">
                                <i class="bi bi-x"></i> Cancel
                            </button>
                        </div>
                        <small id="phoneErrorMessage" class="text-danger d-none mt-2"></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div id="successAlert" class="alert alert-success alert-dismissible fade d-none" role="alert">
    <span id="successMessage"></span>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

@section Scripts {
    <script>
        function showSuccessMessage(message) {
            const alert = document.getElementById('successAlert');
            const messageSpan = document.getElementById('successMessage');
            messageSpan.textContent = message;
            alert.classList.remove('d-none');
            alert.classList.add('show');
            setTimeout(() => {
                alert.classList.remove('show');
                alert.classList.add('d-none');
            }, 5000);
        }
        document.getElementById('editUsernameBtn').addEventListener('click', function() {
            document.getElementById('editModeContainer').classList.remove('d-none');
            document.getElementById('usernameInput').focus();
            this.style.display = 'none';
        });

        document.getElementById('cancelUsernameBtn').addEventListener('click', function() {
            document.getElementById('editModeContainer').classList.add('d-none');
            document.getElementById('editUsernameBtn').style.display = 'block';
            document.getElementById('usernameInput').value = '@Html.Raw(currentUsername)';
            document.getElementById('errorMessage').classList.add('d-none');
        });

        document.getElementById('saveUsernameBtn').addEventListener('click', async function() {
            const newUsername = document.getElementById('usernameInput').value.trim();
            const errorMessage = document.getElementById('errorMessage');

            if (!newUsername) {
                errorMessage.textContent = 'Username cannot be empty.';
                errorMessage.classList.remove('d-none');
                return;
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch('@Url.Page("/Account/Manage/Index", new {handler="UpdateUsername"})', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': token || ''
                    },
                    body: JSON.stringify({ newUsername: newUsername })
                });

                const data = await response.json();

                if (!response.ok) {
                    errorMessage.textContent = data.message || 'Failed to update username.';
                    errorMessage.classList.remove('d-none');
                    return;
                }

                // Update display
                document.getElementById('usernameDisplay').value = newUsername;
                document.getElementById('editModeContainer').classList.add('d-none');
                document.getElementById('editUsernameBtn').style.display = 'block';
                errorMessage.classList.add('d-none');

                showSuccessMessage('Username updated successfully!');
            } catch (error) {
                errorMessage.textContent = 'An error occurred while updating username.';
                errorMessage.classList.remove('d-none');
            }
        });

        document.getElementById('editPhoneBtn').addEventListener('click', function() {
            document.getElementById('editPhoneModeContainer').classList.remove('d-none');
            document.getElementById('phoneInput').focus();
            this.style.display = 'none';
        });

        document.getElementById('cancelPhoneBtn').addEventListener('click', function() {
            document.getElementById('editPhoneModeContainer').classList.add('d-none');
            document.getElementById('editPhoneBtn').style.display = 'block';
            document.getElementById('phoneInput').value = '@Html.Raw(currentPhone)';
            document.getElementById('phoneErrorMessage').classList.add('d-none');
        });

        document.getElementById('savePhoneBtn').addEventListener('click', async function() {
            const newPhone = document.getElementById('phoneInput').value.trim();
            const phoneErrorMessage = document.getElementById('phoneErrorMessage');

            try {
                const response = await fetch('@Url.Page("/Account/Manage/Index", new {handler="UpdatePhone"})', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ newPhone: newPhone })
                });

                const data = await response.json();

                if (!response.ok) {
                    phoneErrorMessage.textContent = data.message || 'Failed to update phone number.';
                    phoneErrorMessage.classList.remove('d-none');
                    return;
                }

                // Update display
                document.getElementById('phoneDisplay').value = newPhone || 'Not set';
                document.getElementById('editPhoneModeContainer').classList.add('d-none');
                document.getElementById('editPhoneBtn').style.display = 'block';
                phoneErrorMessage.classList.add('d-none');

                showSuccessMessage('Phone number updated successfully!');
            } catch (error) {
                phoneErrorMessage.textContent = 'An error occurred while updating phone number.';
                phoneErrorMessage.classList.remove('d-none');
            }
        });
    </script>
}
