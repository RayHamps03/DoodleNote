@model DoodleNote
@{
    ViewData["Title"] = "Edit Doodle Note";
}

<h1>Edit Doodle Note</h1>

<form id="editNoteForm" method="post" asp-action="Edit" asp-route-id="@Model.NoteId" onsubmit="return handleEditNote(event)">
    <input type="hidden" name="NoteId" value="@Model.NoteId" />
    <div class="mb-3">
        <label for="noteTitle" class="form-label">Note Title</label>
        <input id="noteTitle" name="NoteTitle" class="form-control" maxlength="25" value="@Model.NoteTitle" required />
    </div>

    <div class="mb-3">
        <label class="form-label d-block">Note Canvas</label>
        <div style="min-height: 260px; border: 1px solid #ced4da; border-radius: 0.375rem; background-color: #f8f9fa; box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.15);"></div>
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea id="description" name="Description" class="form-control" rows="4" maxlength="300">@Model.Description</textarea>
        <div class="form-text">
            <span id="descriptionCount">0</span> / 300 characters
        </div>
    </div>

    <div class="mb-3">
        <button type="button" class="btn btn-outline-primary">Invite</button>
    </div>

    <button type="submit" class="btn btn-warning">Save</button>
    <a class="btn btn-secondary btn-danger" asp-action="Index">Cancel</a>
</form>

<!-- Modal -->
<div class="modal fade" id="noDescriptionModal" tabindex="-1" aria-labelledby="noDescriptionModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="noDescriptionModalLabel">No Description Provided</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to save this note without a description?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-warning" id="confirmNoDescription">Yes, Save Note</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        const description = document.getElementById('description');
        const descriptionCount = document.getElementById('descriptionCount');
        const form = document.getElementById('editNoteForm');
        let submitAnyway = false;

        const updateCount = () => {
            descriptionCount.textContent = description.value.length;
        };
        description.addEventListener('input', updateCount);
        updateCount();

        function handleEditNote(e) {
            if (submitAnyway) {
                return true;
            }
            if (!description.value.trim()) {
                e.preventDefault();
                const modal = new bootstrap.Modal(document.getElementById('noDescriptionModal'));
                modal.show();
                return false;
            }
            return true;
        }

        document.getElementById('confirmNoDescription').addEventListener('click', function () {
            submitAnyway = true;
            bootstrap.Modal.getInstance(document.getElementById('noDescriptionModal')).hide();
            setTimeout(() => form.requestSubmit(), 200);
        });
    </script>
}
