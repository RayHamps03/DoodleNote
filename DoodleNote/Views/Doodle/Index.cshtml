
<div>
    <canvas id="canvas" width="300" height="300" ></canvas>

    <!-- Fabric canvas -->
    <script>
    const canvas = new fabric.Canvas('canvas');
    const rect = new fabric.Rect({
      top: 100,
      left: 100,
      width: 60,
      height: 70,
      fill: 'red',
    });
    canvas.add(rect);

    </script>
</div>